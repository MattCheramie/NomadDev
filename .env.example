# NomadDev orchestrator environment

# Required: at least 32 bytes of entropy (base64 or hex encoded).
# Generate with: head -c 48 /dev/urandom | base64
NOMADDEV_JWT_SECRET=changeme_use_at_least_32_random_bytes_here_xxxxxxxxxx

# Optional overrides
NOMADDEV_LISTEN_ADDR=:8080
NOMADDEV_LOG_LEVEL=info

# Web settings editor (Settings -> Server configuration in the SPA).
# Changes made there are persisted to a JSON override file at the path
# below; on the next restart config.Load() layers that file UNDER the real
# environment, so a variable hard-pinned in this file still wins. The path
# must be writable by the daemon — keep it under /var/lib/nomaddev (the env
# file /etc/nomaddev/env is read-only to the orchestrator). The editor's
# API (/admin/config) is gated by JWT scopes: mint operator tokens with
# `config:read` to view settings and `config:write` to change them and
# request a config-change restart. Tokens carrying no `config:` scope keep
# full access for backwards compatibility.
NOMADDEV_CONFIG_OVERRIDE_PATH=/var/lib/nomaddev/config-override.json

# Phase 11.2: OpenTelemetry tracing. Default off — spans become a no-op
# at every instrumentation site so the orchestrator pays only tracer-noop
# overhead until an operator opts in. Set ENABLED=true and point
# OTLP_ENDPOINT at an OTLP/HTTP collector (e.g. otel-collector.tailnet:4318)
# to ship spans. INSECURE=true skips TLS — fine when the collector is on
# the same Tailscale tailnet.
NOMADDEV_OTEL_ENABLED=false
NOMADDEV_OTEL_OTLP_ENDPOINT=
NOMADDEV_OTEL_SERVICE_NAME=nomaddev-orchestrator
NOMADDEV_OTEL_SERVICE_VERSION=
NOMADDEV_OTEL_SAMPLE_RATIO=1.0
NOMADDEV_OTEL_INSECURE=true

# Phase 12.3: WebAuthn / security-key authentication. Optional; see
# docs/webauthn.md for the operator workflow. Requires the SPA to be
# served over HTTPS (or localhost) — the browser refuses WebAuthn
# ceremonies on plain HTTP. RPID must be a suffix of every allowed
# origin's hostname. Changing RPID invalidates existing keys.
NOMADDEV_WEBAUTHN_ENABLED=false
NOMADDEV_WEBAUTHN_RPID=
NOMADDEV_WEBAUTHN_RP_DISPLAY_NAME=NomadDev
NOMADDEV_WEBAUTHN_ORIGINS=
NOMADDEV_WEBAUTHN_STORE_PATH=/var/lib/nomaddev/webauthn.db

# Phase 8.5 audit log: structured security-event sink, separate from the
# per-session replay buffer. JSON Lines, one event per line, ready for
# SIEM / promtail / syslog forwarders. Backend: none (silent) | stderr
# (default, mixes with regular slog stream — grep by "kind") | stdout
# (for sidecar log shippers) | file (path below; appended, 0o600).
# Events: ws.connect, ws.auth_failed, auth.refresh, auth.revoke,
# approval.granted, approval.denied.
NOMADDEV_AUDIT_BACKEND=stderr
NOMADDEV_AUDIT_PATH=/var/lib/nomaddev/audit.log

# Phase 8 auth: access/refresh-token lifetimes and the JTI revocation list.
# Access tokens are short-lived (default 1h) and presented at /ws on every
# connect. Refresh tokens are long-lived (default 30d) and exchanged at
# POST /auth/refresh for a fresh pair; the old refresh JTI is rotated
# into the revocation list so it cannot be replayed.
NOMADDEV_AUTH_ACCESS_TTL=1h
NOMADDEV_AUTH_REFRESH_TTL=720h
# Revocation backend: sqlite (durable, default), memory (lost on restart),
# none (disable revocation entirely — pre-Phase-8 behavior).
NOMADDEV_AUTH_REVOCATION_BACKEND=sqlite
NOMADDEV_AUTH_REVOCATION_PATH=/var/lib/nomaddev/revocations.db
NOMADDEV_AUTH_REVOCATION_JANITOR_INTERVAL=5m

# Docker-compose-only knobs (ignored by the orchestrator binary itself).
# NOMADDEV_BIND_ADDR is the host-side interface docker compose publishes
# :8080 on. Default 127.0.0.1 keeps a bare `docker compose up` safe; for a
# real Tailscale deploy, set this to the host's tailnet IPv4 (the output
# of `tailscale ip -4`) so phones on the tailnet can reach the SPA.
NOMADDEV_BIND_ADDR=127.0.0.1
# NOMADDEV_IMAGE overrides the published image tag.
# NOMADDEV_IMAGE=ghcr.io/mattcheramie/nomaddev:latest

# Session replay buffer. BACKEND=sqlite survives restarts and rehydrates each
# session's reconnect-replay window from disk; BACKEND=memory wipes on restart.
# If sqlite cannot be opened (e.g. /var/lib is not writable in dev), the
# orchestrator logs a warning and falls back to memory.
NOMADDEV_SESSION_BACKEND=sqlite
NOMADDEV_SESSION_PATH=/var/lib/nomaddev/sessions.db
NOMADDEV_SESSION_BUFFER_SIZE=256
NOMADDEV_SESSION_MAX_BYTES=1048576
NOMADDEV_SESSION_IDLE_TTL=30m
NOMADDEV_SESSION_JANITOR_INTERVAL=5m
NOMADDEV_READ_TIMEOUT=60s
NOMADDEV_WRITE_TIMEOUT=10s
NOMADDEV_PING_INTERVAL=30s

# Phase 8.3: per-connection WS guards.
# Inbound frames larger than this are rejected with a 1009 close code
# before unmarshal — protects against a hostile or runaway client
# trying to OOM the orchestrator with a huge envelope.
NOMADDEV_WS_MAX_MESSAGE_BYTES=262144
# Token-bucket envelope-per-second cap per connection. RATE_BURST is
# the bucket size — short bursts above the rate are OK as long as the
# average stays below. Set RATE_LIMIT=0 to disable.
NOMADDEV_WS_RATE_LIMIT=50
NOMADDEV_WS_RATE_BURST=100

# Phase 10.1: CSRF-style Origin allowlist for the WebSocket upgrade.
# Empty (default) accepts any origin — fine for the Tailscale-fronted
# deploy where there's no meaningful browser-origin boundary.
# Operators behind a TLS reverse proxy populate this with the proxy's
# host(s) for a hard same-origin gate at /ws. Comma-separated,
# case-insensitive exact match. Same-origin / non-browser clients
# without an Origin header always pass.
# Example:
#   NOMADDEV_WS_ALLOWED_ORIGINS=https://nomad.example.com,http://localhost:8080
NOMADDEV_WS_ALLOWED_ORIGINS=

# Phase 10.1: JWT secret rotation grace window. Comma-separated list
# of previous-generation signing secrets the verifier accepts
# alongside NOMADDEV_JWT_SECRET. Tokens signed under any of these
# still verify; new tokens are always signed under JWT_SECRET.
# Rotation workflow:
#   1. Generate a new secret. Set NOMADDEV_JWT_PREV_SECRETS to the
#      current value of NOMADDEV_JWT_SECRET, then update
#      NOMADDEV_JWT_SECRET to the new one. Restart.
#   2. Wait for the longest token TTL (default 30d for refresh)
#      so every live token has been re-issued under the new secret.
#   3. Clear NOMADDEV_JWT_PREV_SECRETS. Restart.
# Same encoding rules as NOMADDEV_JWT_SECRET (base64 / hex / raw,
# each entry ≥ 32 bytes decoded).
NOMADDEV_JWT_PREV_SECRETS=

# Phase 3 sandbox runner. RUNTIME=mock is the default in this build; switch to
# "docker" only after rebuilding with -tags docker (see Makefile build-docker
# target). "none" disables the runner and command.request returns
# error{not_implemented}.
NOMADDEV_SANDBOX_RUNTIME=mock
# IMAGE accepts either a tag-only ref ("alpine:3.20") or a digest-pinned
# ref ("alpine:3.20@sha256:..."). Production deploys SHOULD pin by
# digest to defend against a tag-race where a compromised registry
# repoints "alpine:3.20" at a malicious manifest. Pinned example:
#   NOMADDEV_SANDBOX_IMAGE=alpine:3.20@sha256:beefdbd8a1da6d2915566fde36db9db0b524443b0e02132e95eaa10d35aba9b7
# To enable the search_syntax tool, build the dedicated worker image
# (Dockerfile target "sandbox") which pre-installs ast-grep, then point
# this at the resulting tag — runtime apk-add isn't an option when
# NOMADDEV_SANDBOX_NETWORK=none (the default).
#   docker build --target sandbox -t nomaddev/sandbox:bookworm-sg .
#   NOMADDEV_SANDBOX_IMAGE=nomaddev/sandbox:bookworm-sg
NOMADDEV_SANDBOX_IMAGE=alpine:3.20
# When true, refuse to boot unless IMAGE carries an @sha256:... suffix.
# Default false for back-compat; flip to true on hardened deploys.
NOMADDEV_SANDBOX_REQUIRE_DIGEST=false
NOMADDEV_SANDBOX_WORKSPACE_DIR=/var/lib/nomaddev/work
NOMADDEV_SANDBOX_NETWORK=none
NOMADDEV_SANDBOX_DEFAULT_TIMEOUT=30s
NOMADDEV_SANDBOX_MAX_CONCURRENT=4
NOMADDEV_SANDBOX_MEMORY=268435456
NOMADDEV_SANDBOX_NANOCPUS=1000000000
NOMADDEV_SANDBOX_PIDS_LIMIT=256
NOMADDEV_SANDBOX_READONLY_ROOTFS=true
NOMADDEV_SANDBOX_PREFER_RUNSC=true
# Phase 10.2: scope the bind-mounted /work to a per-SID subdir of
# WorkspaceDir so two sessions can't see each other's files via the
# sandbox path. fsops still operates on the shared root (deferred to
# a later phase). Default false preserves the single-tenant shared
# workspace.
NOMADDEV_SANDBOX_PER_SESSION_WORKSPACE=false

# Daemon monitoring: enables the monitor_daemon / stop_daemon / list_daemons
# tools. monitor_daemon starts a long-running command as a detached process
# on the orchestrator HOST (outside the ephemeral-container boundary, like
# the worker pool's host-side git) and streams its output back as
# system.log_event envelopes. Opt-in and off by default because it grants a
# host-execution privilege; monitor_daemon is always approval-gated. See
# docs/sandbox.md.
NOMADDEV_DAEMON_MONITOR_ENABLED=false

# Phase 4 NLP middleware. RUNTIME=mock returns canned assistant frames so the
# default build is testable without an API key. Each non-mock runtime is gated
# behind its own build tag — pick the matching make target before switching:
#   gemini    → make build-gemini
#   openai    → make build-openai     (also covers deepseek)
#   anthropic → make build-anthropic
#   deepseek  → make build-openai     (DeepSeek is OpenAI-compatible)
# Temperature / MaxTokens below apply to whichever runtime is active.
#
# The NOMADDEV_*_MODEL value below is the *default* model for the active
# runtime. Within one provider the model can be switched at runtime from
# the mobile Settings screen (user.command{set_model}); the override is
# per-session and held in memory, so a restart returns every session to
# the value set here. Switching the provider itself still requires
# editing NOMADDEV_MIDDLEWARE_RUNTIME and restarting.
NOMADDEV_MIDDLEWARE_RUNTIME=mock
NOMADDEV_GEMINI_API_KEY=
NOMADDEV_GEMINI_MODEL=gemini-2.0-flash
NOMADDEV_GEMINI_TEMPERATURE=0.2
NOMADDEV_GEMINI_MAX_TOKENS=4096
# OpenAI Chat Completions (build with -tags openai).
NOMADDEV_OPENAI_API_KEY=
NOMADDEV_OPENAI_MODEL=gpt-4o-mini
NOMADDEV_OPENAI_BASE_URL=
# Anthropic Messages API (build with -tags anthropic).
NOMADDEV_ANTHROPIC_API_KEY=
NOMADDEV_ANTHROPIC_MODEL=claude-sonnet-4-5
# DeepSeek (build with -tags openai; reuses OpenAI client with DeepSeek base URL).
NOMADDEV_DEEPSEEK_API_KEY=
# deepseek-chat (default) is text-only; set NOMADDEV_DEEPSEEK_MODEL=deepseek-vl2
# to enable vision (image attachments). deepseek-reasoner is also text-only.
NOMADDEV_DEEPSEEK_MODEL=deepseek-chat
NOMADDEV_MIDDLEWARE_SYSTEM_PROMPT=
NOMADDEV_MIDDLEWARE_SYSTEM_PROMPT_PATH=
NOMADDEV_MIDDLEWARE_MAX_CONCURRENT=4
# Transport-level retry budget for the active LLM SDK (OpenAI + Anthropic
# both retry 408/409/429/5xx with exponential backoff). Gemini's policy is
# hardcoded by the SDK and not overridable. 0 keeps each SDK at its default
# (2 retries for OpenAI/Anthropic).
NOMADDEV_LLM_MAX_RETRIES=2
# Anthropic extended thinking: token budget for the model's internal
# reasoning. 0 = disabled (default). Anthropic requires a value >= 1024 and
# strictly less than NOMADDEV_GEMINI_MAX_TOKENS-style cap on the active
# runtime; an out-of-range value is rejected by the API at first call.
# Ignored when the active runtime is not "anthropic". When set, the
# orchestrator emits assistant.thinking envelopes alongside the usual
# assistant.chunk stream so clients can render the reasoning separately.
NOMADDEV_ANTHROPIC_THINKING_BUDGET=0
# Multimodal user.intent attachments. The mobile UI ships an image picker
# that base64-encodes the picked file and includes it in the envelope's
# `images` field; the orchestrator validates count + decoded size and
# forwards to whichever LLM backend is active. Set either value to 0 to
# refuse all image attachments. Allowed media types are restricted to
# image/jpeg, image/png, image/gif, and image/webp (intersection of the
# providers' supported sets).
#
# Vision capability is a per-(provider, model) property — see
# internal/middleware/pricing/capabilities.go. The orchestrator rejects
# image-bearing intents up-front with bad_envelope when the active
# runtime+model is known text-only (e.g. openai/o3-mini,
# deepseek/deepseek-chat). Pair the DeepSeek runtime with
# NOMADDEV_DEEPSEEK_MODEL=deepseek-vl2 to use vision; OpenAI/Anthropic/Gemini
# defaults are already vision-capable.
NOMADDEV_USER_INTENT_MAX_IMAGES=4
NOMADDEV_USER_INTENT_MAX_IMAGE_BYTES=5242880

# Phase 13 automated error recovery. Caps consecutive failed tool-call
# dispatches inside one user.intent before the middleware escalates to the
# Mobile Control Hub. On a retryable failure (non-zero exit, sandbox
# timeout, OOM) the orchestrator feeds a structured system.error_report
# back into the translation layer so the LLM can author a fix as a new
# command.request. Once the budget is spent, the failure is forwarded to
# the connected mobile client as a system.error_report envelope and the
# turn ends with finish_reason=error. 0 disables the loop (first failure
# escalates immediately).
NOMADDEV_MAX_AUTORETRIES=2

# Phase 4 persistent history (SQLite). BACKEND=memory wipes on restart.
NOMADDEV_HISTORY_BACKEND=sqlite
NOMADDEV_HISTORY_PATH=/var/lib/nomaddev/history.db
NOMADDEV_HISTORY_WINDOW_TURNS=20

# Phase 4 human-in-the-loop approval gate.
NOMADDEV_APPROVAL_REQUIRED_TOOLS=execute_script,write_patch
NOMADDEV_APPROVAL_TIMEOUT=60s
NOMADDEV_APPROVAL_AUTO_GRANT=false
NOMADDEV_APPROVAL_GATE_DIRECT_COMMANDS=true

# Phase 15 concurrent worker pool. Opt-in — disabled by default because it
# grants the orchestrator a new privilege: it shells out to the host `git`
# binary (worktree add/remove, commit, merge) against
# NOMADDEV_SANDBOX_WORKSPACE_DIR, which must be a pre-cloned git repo. This
# is outside the Docker sandbox boundary the rest of NomadDev runs inside;
# every git invocation passes `-c core.hooksPath=/dev/null` so attacker-
# influenced repo hooks never execute on the host. When ENABLED=true the
# LLM gains a `dispatch_worker_pool` tool that fans a code migration out
# across isolated git worktrees, forks the conversation context into one
# headless sub-dispatcher per sub-task, runs them in parallel, and merges
# each finished branch back into the primary branch. Requires
# NOMADDEV_SANDBOX_PER_SESSION_WORKSPACE=false (the per-session layout is
# incompatible with the shared-root git repo). Every mutating tool call a
# sub-dispatcher makes still goes through the normal human-approval gate.
NOMADDEV_WORKER_POOL_ENABLED=false
# Server-wide semaphore capping concurrent headless sub-dispatchers.
NOMADDEV_WORKER_POOL_MAX=4
# Cap on the length of the `tasks` array a single dispatch_worker_pool
# call may carry.
NOMADDEV_WORKER_POOL_MAX_TASKS=8
# Per-sub-dispatcher wall-clock timeout. A task that runs past this is
# canceled; its worktree branch is kept for inspection.
NOMADDEV_WORKER_POOL_TASK_TIMEOUT=10m

# Comma-separated allowlist for the `fetch_external_docs` tool. When set, the
# tool may only fetch these domains and their subdomains; every other host is
# refused. Leave empty to permit any public host — either way the docfetch
# exfiltration screen still refuses URLs that embed credentials or carry a
# secret-shaped value, so a crafted URL cannot smuggle data out.
# Example: NOMADDEV_DOC_FETCH_ALLOWED_DOMAINS=docs.python.org,*.readthedocs.io
NOMADDEV_DOC_FETCH_ALLOWED_DOMAINS=

# Phase 5 hosted SPA. ENABLED=true serves the embedded UI at "/". Set DIR to
# serve from a host directory instead (useful during `expo start --web`).
NOMADDEV_SPA_ENABLED=true
NOMADDEV_SPA_DIR=

# GitHub MCP integration. Requires `-tags github` at build time AND the
# `github-mcp-server` binary installed on PATH (or NOMADDEV_GITHUB_MCP_BIN).
# When TOKEN is empty the orchestrator boots without any github_* tools.
# Recommended PAT: fine-grained, with Contents:rw, Issues:rw, Pull requests:rw,
# Actions:rw, Metadata:r, Workflows:rw, Discussions:rw for the default surface.
# Every mutating tool is auto-added to the approval gate at startup.
NOMADDEV_GITHUB_TOKEN=
NOMADDEV_GITHUB_MCP_BIN=
NOMADDEV_GITHUB_TOOLSETS=all
NOMADDEV_GITHUB_READ_ONLY=false
NOMADDEV_GITHUB_HOST=
NOMADDEV_GITHUB_LOCKDOWN=false
NOMADDEV_GITHUB_START_TIMEOUT=15s
# Cap on a single tool call's JSON-marshaled args, defends against a
# misbehaving LLM stuffing a 100 MB blob into a PR body. Set to 0 to
# disable.
NOMADDEV_GITHUB_MAX_ARG_BYTES=262144
# Cap on the JSON payload returned to the model. A get_file_contents
# returning a 50 MB blob would otherwise blow Gemini's context window;
# oversized results are replaced with a preview + truncation marker the
# model can self-correct on. Set to 0 to disable.
# Also gates the search_syntax sandbox tool (Phase 12.x): when sg's
# match envelope exceeds the cap, the reshaper drops trailing matches
# until the envelope fits and sets a truncated:true marker.
NOMADDEV_GITHUB_MAX_RESULT_BYTES=1048576
# Path to a JSON file mapping JWT sub → fine-grained PAT for per-user
# token routing ({"alice":"ghp_xxx","bob":"ghp_yyy"}). When unset, every
# user shares the single NOMADDEV_GITHUB_TOKEN above. Per-user entries
# fall through to that shared token on miss. File is re-read on mtime
# change so rotation is "edit, no restart needed."
NOMADDEV_GITHUB_USER_TOKENS_PATH=
# Phase 8.9 — bounded retry when GitHub returns a primary or secondary
# rate-limit error. The client backs off exponentially (BASE_BACKOFF,
# 2*BASE_BACKOFF, 4*BASE_BACKOFF, … capped at 30s with jitter) up to
# RATE_LIMIT_RETRIES attempts, honoring any Retry-After hint the
# upstream surfaces in the error text. Set RATE_LIMIT_RETRIES=0 to
# disable (pre-8.9 behavior — first rate-limit error surfaces to the
# model). nomaddev_github_rate_limit_retries_total{outcome} counts
# retried vs gave_up.
NOMADDEV_GITHUB_RATE_LIMIT_RETRIES=3
NOMADDEV_GITHUB_RATE_LIMIT_BASE_BACKOFF=1s
