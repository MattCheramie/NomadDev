# NomadDev orchestrator environment

# Required: at least 32 bytes of entropy (base64 or hex encoded).
# Generate with: head -c 48 /dev/urandom | base64
NOMADDEV_JWT_SECRET=changeme_use_at_least_32_random_bytes_here_xxxxxxxxxx

# Optional overrides
NOMADDEV_LISTEN_ADDR=:8080
NOMADDEV_LOG_LEVEL=info
NOMADDEV_SESSION_BUFFER_SIZE=256
NOMADDEV_SESSION_MAX_BYTES=1048576
NOMADDEV_SESSION_IDLE_TTL=30m
NOMADDEV_SESSION_JANITOR_INTERVAL=5m
NOMADDEV_READ_TIMEOUT=60s
NOMADDEV_WRITE_TIMEOUT=10s
NOMADDEV_PING_INTERVAL=30s

# Phase 3 sandbox runner. RUNTIME=mock is the default in this build; switch to
# "docker" only after rebuilding with -tags docker (see Makefile build-docker
# target). "none" disables the runner and command.request returns
# error{not_implemented}.
NOMADDEV_SANDBOX_RUNTIME=mock
NOMADDEV_SANDBOX_IMAGE=alpine:3.20
NOMADDEV_SANDBOX_WORKSPACE_DIR=/var/lib/nomaddev/work
NOMADDEV_SANDBOX_NETWORK=none
NOMADDEV_SANDBOX_DEFAULT_TIMEOUT=30s
NOMADDEV_SANDBOX_MAX_CONCURRENT=4
NOMADDEV_SANDBOX_MEMORY=268435456
NOMADDEV_SANDBOX_NANOCPUS=1000000000
NOMADDEV_SANDBOX_PIDS_LIMIT=256
NOMADDEV_SANDBOX_READONLY_ROOTFS=true
NOMADDEV_SANDBOX_PREFER_RUNSC=true
